# Event Planner App - Environment Variables Template
# Copy this file to .env and fill in your actual values

# LLM API Keys (optional - app works without them)
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
COHERE_API_KEY=your_cohere_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here

# Google Maps API (optional)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your_secret_key_here_generate_a_secure_one

# Database Configuration
# For local development (SQLite)
DATABASE_URL=sqlite:///instance/events.db

# For production (PostgreSQL on Railway)
# DATABASE_URL=postgresql://username:password@host:port/database

# Local JSON → production DB sync (scripts/sync_json_to_production.py only — not used by the Flask app)
# Prefer this so DATABASE_URL can stay sqlite:/// for local development:
# PRODUCTION_DATABASE_URL=postgresql://username:password@YOUR_PUBLIC_HOST:port/database

# Google Vision API (for OCR in production)
# Place your google-vision-credentials.json in the config/ directory

# Railway Deployment (automatically set by Railway)
# PORT=5001
# RAILWAY_ENVIRONMENT=production
GOOGLE_ANALYTICS_ID=

# Optional Stripe Payment Link for “Support this project” (footer hidden when unset)
PLANNER_SUPPORT_URL=

# Webshare residential proxy (scrapers that call scraper_proxy_opt_in: NGA, Finding Awe, Asian Art, SAAM)
# WEBSHARE_PROXY_URL=http://username:password@p.webshare.io:80
# WEBSHARE_PROXY_HTTP=http://username:password@p.webshare.io:80
# WEBSHARE_PROXY_HTTPS=http://username:password@p.webshare.io:80
#
# Railway / deployed: when WEBSHARE_* is set, proxy is ON by default for wired scrapers.
# Local: proxy OFF by default (direct requests) unless you set one of:
#   USE_PROXY_<KEY>=1   e.g. USE_PROXY_NGA=1
#   SCRAPER_PROXY_LOCAL_ENABLED=1   (all wired scrapers use proxy when WEBSHARE_* is set)
#   PLANNER_SIMULATE_DEPLOY_PROXY=1   (treat machine like Railway for proxy defaults)
#
# Disable (escape hatches):
# SCRAPER_PROXY_GLOBAL_DISABLED=1   or   WEBSHARE_PROXY_DISABLED=1   — no scraper uses proxy
# DISABLE_PROXY_<KEY>=1   e.g. DISABLE_PROXY_NGA=1   — one scraper off on deploy
# USE_PROXY_<KEY>=0   — per-scraper off
#PRODUCTION_DATABASE_URL=
